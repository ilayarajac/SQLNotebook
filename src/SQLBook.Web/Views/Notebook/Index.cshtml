@model SQLBook.Web.Models.Notebook
@inject Microsoft.Extensions.Configuration.IConfiguration Config
@{
    ViewData["Title"] = Model.Title;
    var dbProvider = Config["DefaultConnection:Provider"] is { Length: > 0 } p ? p : "sqlite";
}

<div class="notebook-layout d-flex" data-db-provider="@dbProvider" style="min-height: calc(100vh - 56px);">
@{ /* pass db provider to editor.js via body dataset */ }
<script>document.body.dataset.dbProvider = '@dbProvider';</script>

    <!-- Schema Sidebar -->
    <aside class="schema-sidebar border-end bg-light p-2" style="width:220px; min-width:220px; overflow-y:auto;">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <small class="fw-bold text-muted text-uppercase">Schema</small>
            <button class="btn btn-sm btn-outline-secondary py-0"
                    hx-get="/schema"
                    hx-target="#schema-tree"
                    hx-swap="innerHTML">⟳</button>
        </div>
        <div id="schema-tree"
             hx-get="/schema"
             hx-trigger="load"
             hx-swap="innerHTML">
            <small class="text-muted">Loading...</small>
        </div>
    </aside>

    <!-- Main Editor Area -->
    <div class="flex-grow-1 p-3">

        <!-- Notebook Title -->
        <div class="mb-3 position-relative title-wrap">
            <input type="text"
                   id="notebook-title"
                   value="@Model.Title"
                   class="form-control form-control-lg fw-bold border-0 border-bottom rounded-0 px-0 pe-4"
                   placeholder="Untitled Notebook"
                   hx-post="/notebook/@Model.Id/autosave"
                   hx-trigger="input delay:800ms"
                   hx-swap="none"
                   name="title"
                   title="Click to rename" />
            <span class="title-edit-hint text-muted" style="position:absolute;right:4px;top:50%;transform:translateY(-50%);pointer-events:none;font-size:0.85rem;">✏</span>
            <span id="title-saved-indicator"
                  class="text-success ms-2 small"
                  style="display:none;position:absolute;right:28px;top:50%;transform:translateY(-50%);"
                  hx-on:htmx:after-request="this.style.display='inline';setTimeout(()=>this.style.display='none',1500)">✓ saved</span>
        </div>

        <!-- Notebook Toolbar -->
        <div class="mb-2 d-flex justify-content-end">
            <button id="run-all-btn" class="btn btn-sm btn-success">▶▶ Run All</button>
        </div>

        <!-- Cells Container -->
        <div id="cells-container">
            @foreach (var cell in Model.Cells.OrderBy(c => c.Order))
            {
                @await Html.PartialAsync("_Cell", (Model, cell))
            }
        </div>

        <!-- Add Cell Buttons -->
        <div class="mt-3 d-flex gap-2">
            <button class="btn btn-sm btn-outline-primary"
                    hx-post="/notebook/@Model.Id/cell/add"
                    hx-vals='{"type":"sql"}'
                    hx-target="#cells-container"
                    hx-swap="beforeend">
                + SQL Cell
            </button>
            <button class="btn btn-sm btn-outline-secondary"
                    hx-post="/notebook/@Model.Id/cell/add"
                    hx-vals='{"type":"markdown"}'
                    hx-target="#cells-container"
                    hx-swap="beforeend">
                + Markdown Cell
            </button>
        </div>
    </div>
</div>

@section Scripts {
<script src="~/js/editor.bundle.js" asp-append-version="true"></script>
}
