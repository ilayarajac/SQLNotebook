@model (SQLBook.Web.Models.Notebook Notebook, SQLBook.Web.Models.Cell Cell)
@{
    var nb = Model.Notebook;
    var cell = Model.Cell;
}

<div class="nb-cell card mb-3" id="cell-@cell.Id" data-cell-id="@cell.Id">
    <div class="card-header d-flex justify-content-between align-items-center py-1 px-3 bg-light">
        <span class="badge @(cell.Type == "sql" ? "bg-primary" : "bg-secondary") me-2">@cell.Type.ToUpper()</span>

        <div class="ms-auto d-flex gap-1">
            @if (cell.Type == "sql")
            {
                <button id="run-@cell.Id"
                        class="btn btn-sm btn-success btn-run"
                        hx-post="/query/run"
                        hx-target="#result-@cell.Id"
                        hx-swap="innerHTML"
                        hx-include="#cell-form-@cell.Id">
                    ▶ Run
                </button>
            }
            <button class="btn btn-sm btn-outline-danger"
                    hx-delete="/notebook/@nb.Id/cell/@cell.Id"
                    hx-target="#cell-@cell.Id"
                    hx-swap="outerHTML"
                    hx-confirm="Delete this cell?">
                ✕
            </button>
        </div>
    </div>

    <div class="card-body p-0">
        @if (cell.Type == "sql")
        {
            <form id="cell-form-@cell.Id">
                <input type="hidden" name="cellId" value="@cell.Id" />
                <div class="cm-host"
                     data-cell-id="@cell.Id"
                     data-content="@Html.Raw(System.Web.HttpUtility.HtmlAttributeEncode(cell.Content))">
                </div>
                <input type="hidden" id="sql-@cell.Id" name="content" value="@cell.Content" />
            </form>
            <span id="autosave-trigger-@cell.Id"
                  hx-post="/notebook/@nb.Id/autosave"
                  hx-trigger="sqlbook:autosave"
                  hx-swap="none"
                  hx-include="#cell-form-@cell.Id, #notebook-title"
                  style="display:none"></span>
        }
        else
        {
            <form id="cell-form-@cell.Id">
                <input type="hidden" name="cellId" value="@cell.Id" />
                <textarea name="content"
                          class="form-control font-monospace border-0"
                          rows="4"
                          placeholder="# Markdown content..."
                          hx-post="/notebook/@nb.Id/autosave"
                          hx-trigger="input delay:800ms"
                          hx-swap="none"
                          hx-include="#cell-form-@cell.Id, #notebook-title">@cell.Content</textarea>
            </form>
        }
    </div>

    <div id="result-@cell.Id" class="cell-result"></div>
</div>
