@model (SQLBook.Web.Models.Notebook Notebook, SQLBook.Web.Models.Cell Cell)
@{
    var nb = Model.Notebook;
    var cell = Model.Cell;
}

<div class="nb-cell card mb-3" id="cell-@cell.Id" data-cell-id="@cell.Id">
    <div class="card-header d-flex justify-content-between align-items-center py-1 px-3 bg-light">
        <span class="cell-drag-handle text-muted me-1" title="Drag to reorder">⠿</span>
        <button class="cell-collapse-btn btn btn-link btn-sm p-0 me-2 text-muted lh-1" title="Collapse">⊖</button>
        <span class="badge @(cell.Type == "sql" ? "bg-primary" : cell.Type == "params" ? "bg-warning text-dark" : "bg-secondary") me-2">@cell.Type.ToUpper()</span>

        <div class="ms-auto d-flex gap-1">
            @if (cell.Type == "sql")
            {
                <button id="run-@cell.Id"
                        class="btn btn-sm btn-success btn-run"
                        hx-post="/query/run"
                        hx-target="#result-@cell.Id"
                        hx-swap="innerHTML"
                        hx-include="#cell-form-@cell.Id">
                    ▶ Run
                </button>
            }
            @if (cell.Type == "markdown")
            {
                <button id="md-toggle-@cell.Id"
                        class="btn btn-sm btn-outline-secondary">
                    👁 Preview
                </button>
            }
            <button class="btn btn-sm btn-outline-danger"
                    hx-delete="/notebook/@nb.Id/cell/@cell.Id"
                    hx-target="#cell-@cell.Id"
                    hx-swap="outerHTML"
                    hx-confirm="Delete this cell?">
                ✕
            </button>
        </div>
    </div>

    <div class="card-body p-0">
        @if (cell.Type == "sql")
        {
            <form id="cell-form-@cell.Id">
                <input type="hidden" name="cellId" value="@cell.Id" />
                <div class="cm-host"
                     data-cell-id="@cell.Id"
                     data-content="@Html.Raw(System.Web.HttpUtility.HtmlAttributeEncode(cell.Content))">
                </div>
                <input type="hidden" id="sql-@cell.Id" name="content" value="@cell.Content" />
            </form>
            <span id="autosave-trigger-@cell.Id"
                  hx-post="/notebook/@nb.Id/autosave"
                  hx-trigger="sqlbook:autosave"
                  hx-swap="none"
                  hx-include="#cell-form-@cell.Id, #notebook-title"
                  style="display:none"></span>
        }
        else if (cell.Type == "params")
        {
            <form id="cell-form-@cell.Id">
                <input type="hidden" name="cellId" value="@cell.Id" />
                <div class="params-host"
                     data-cell-id="@cell.Id">
                    <textarea name="content"
                              class="form-control font-monospace border-0 rounded-0 params-textarea"
                              rows="4"
                              placeholder="@@key = value  (one parameter per line)"
                              hx-post="/notebook/@nb.Id/autosave"
                              hx-trigger="input delay:800ms"
                              hx-swap="none"
                              hx-include="#cell-form-@cell.Id, #notebook-title">@cell.Content</textarea>
                </div>
            </form>
        }
        else
        {
            <form id="cell-form-@cell.Id">
                <input type="hidden" name="cellId" value="@cell.Id" />
                <div class="md-host"
                     data-cell-id="@cell.Id"
                     data-has-content="@(!string.IsNullOrWhiteSpace(cell.Content) ? "true" : "false")">
                    <div id="md-edit-@cell.Id">
                        <textarea name="content"
                                  class="form-control font-monospace border-0 rounded-0"
                                  rows="4"
                                  placeholder="Write markdown here… click Preview to render"
                                  hx-post="/notebook/@nb.Id/autosave"
                                  hx-trigger="input delay:800ms"
                                  hx-swap="none"
                                  hx-include="#cell-form-@cell.Id, #notebook-title">@cell.Content</textarea>
                    </div>
                    <div id="md-preview-@cell.Id" class="md-preview px-3 py-2" style="display:none;"></div>
                </div>
            </form>
        }
    </div>

    <div id="result-@cell.Id" class="cell-result"></div>
</div>
