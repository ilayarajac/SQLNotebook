@model SQLBook.Web.Models.CellResult

@if (Model.HasError)
{
    <div class="alert alert-danger m-2 py-2">
        <strong>Error:</strong> @Model.Error
        <small class="d-block text-muted mt-1">@Model.ElapsedMs ms</small>
    </div>
}
else if (!Model.Columns.Any())
{
    <div class="text-muted small px-3 py-2">Query executed successfully — no rows returned. (@Model.ElapsedMs ms)</div>
}
else
{
    <div class="result-toolbar d-flex justify-content-between align-items-center px-3 py-1 border-top bg-light">
        <small class="text-muted">@Model.RowCount row@(Model.RowCount != 1 ? "s" : "") &bull; @Model.ElapsedMs ms</small>
    </div>
    <div class="table-responsive" style="max-height: 400px; overflow-y: auto;">
        <table class="table table-sm table-bordered table-hover mb-0 result-table">
            <thead class="table-dark sticky-top">
                <tr>
                    @foreach (var col in Model.Columns)
                    {
                        <th>@col</th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var row in Model.Rows)
                {
                    <tr>
                        @foreach (var val in row)
                        {
                            <td>@(val?.ToString() ?? "<null>")</td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
